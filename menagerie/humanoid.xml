<mujoco model="humanoid">
  <option timestep="0.002" gravity="0 0 -9.81" />
  
  <default>
    <joint damping="0.5" armature="0.1" />
    <geom friction="0.8" />
  </default>
  
  <asset>
    <material name="skin" rgba="0.8 0.6 0.4 1" />
    <material name="limb" rgba="0.3 0.3 0.8 1" />
  </asset>
  
  <worldbody>
    <light name="spotlight" mode="targetbodycom" target="torso" pos="0 -2 4" />
    
    <body name="torso" pos="0 0 1.4">
      <freejoint name="root" />
      <geom name="torso_geom" type="capsule" fromto="0 -0.07 0 0 0.07 0" size="0.07" material="skin" mass="5" />
      
      <!-- Head -->
      <body name="head" pos="0 0 0.24">
        <geom name="head_geom" type="sphere" size="0.06" material="skin" mass="0.5" />
      </body>
      
      <!-- Left Arm -->
      <body name="left_upper_arm" pos="0 -0.12 0.07">
        <joint name="left_shoulder" type="hinge" axis="0 1 0" range="-3.14 3.14" />
        <geom name="left_upper_arm_geom" type="capsule" fromto="0 0 0 0.2 0 0" size="0.035" material="limb" mass="1" />
        <body name="left_lower_arm" pos="0.2 0 0">
          <joint name="left_elbow" type="hinge" axis="0 0 1" range="-2.5 0" />
          <geom name="left_lower_arm_geom" type="capsule" fromto="0 0 0 0.18 0 0" size="0.03" material="limb" mass="0.8" />
        </body>
      </body>
      
      <!-- Right Arm -->
      <body name="right_upper_arm" pos="0 0.12 0.07">
        <joint name="right_shoulder" type="hinge" axis="0 1 0" range="-3.14 3.14" />
        <geom name="right_upper_arm_geom" type="capsule" fromto="0 0 0 0.2 0 0" size="0.035" material="limb" mass="1" />
        <body name="right_lower_arm" pos="0.2 0 0">
          <joint name="right_elbow" type="hinge" axis="0 0 1" range="-2.5 0" />
          <geom name="right_lower_arm_geom" type="capsule" fromto="0 0 0 0.18 0 0" size="0.03" material="limb" mass="0.8" />
        </body>
      </body>
      
      <!-- Left Leg -->
      <body name="left_upper_leg" pos="0 -0.07 -0.15">
        <joint name="left_hip" type="hinge" axis="1 0 0" range="-1.5 1.5" />
        <geom name="left_upper_leg_geom" type="capsule" fromto="0 0 0 0 -0.2 -0.1" size="0.05" material="limb" mass="2" />
        <body name="left_lower_leg" pos="0 -0.2 -0.1">
          <joint name="left_knee" type="hinge" axis="1 0 0" range="-2.5 0" />
          <geom name="left_lower_leg_geom" type="capsule" fromto="0 0 0 0 -0.15 -0.05" size="0.04" material="limb" mass="1.5" />
          <body name="left_foot" pos="0 -0.15 -0.05">
            <geom name="left_foot_geom" type="capsule" fromto="0.05 0 -0.03 -0.05 0 -0.03" size="0.035" material="skin" mass="0.5" />
          </body>
        </body>
      </body>
      
      <!-- Right Leg -->
      <body name="right_upper_leg" pos="0 0.07 -0.15">
        <joint name="right_hip" type="hinge" axis="1 0 0" range="-1.5 1.5" />
        <geom name="right_upper_leg_geom" type="capsule" fromto="0 0 0 0 -0.2 -0.1" size="0.05" material="limb" mass="2" />
        <body name="right_lower_leg" pos="0 -0.2 -0.1">
          <joint name="right_knee" type="hinge" axis="1 0 0" range="-2.5 0" />
          <geom name="right_lower_leg_geom" type="capsule" fromto="0 0 0 0 -0.15 -0.05" size="0.04" material="limb" mass="1.5" />
          <body name="right_foot" pos="0 -0.15 -0.05">
            <geom name="right_foot_geom" type="capsule" fromto="0.05 0 -0.03 -0.05 0 -0.03" size="0.035" material="skin" mass="0.5" />
          </body>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>
